# =======================
# PDP-SMART - .gitignore 
# =======================

# -------------------------
# DIPENDENZE E LOGS (Globale)
# -------------------------
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# -------------------------
# BACKEND (Node/Express/Prisma)
# -------------------------
# Sicurezza: Chiavi e Certificati SSL
backend/keys/
*.pem
*.key
*.crt

# Prisma: Client generato e DB locali
backend/prisma/generated/
backend/prisma/*.db
backend/prisma/*.db-journal
node_modules/.prisma

# Environment Variables (ignoriamo tutti tranne esempi)
**/.env
!.env.example

# -------------------------
# FRONTEND (Angular)
# -------------------------
frontend/dist/
frontend/.angular/
frontend/.cache/
frontend/.tmp/
frontend/out-tsc/
frontend/src/environments/*.local.ts
frontend/tmp/
frontend/temp/

# -------------------------
# BUILD & TYPESCRIPT
# -------------------------
dist/
build/
*.tsbuildinfo

# -------------------------
# TEST E REPORT
# -------------------------
coverage/
test-results/

# -------------------------
# IDE E SISTEMA OPERATIVO
# -------------------------
# VS Code (manteniamo solo config utili)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ / JetBrains
.idea/
*.iml

# Mac / Windows
.DS_Store
Thumbs.db
*.local
*.suo